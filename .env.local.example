# Admin panel mock-mode flag. When `true`, lib/api/auth.ts (and Plan B/C admin
# API modules) dispatch to lib/mock/* instead of hitting the backend.
NEXT_PUBLIC_API_MOCK=true

# Backend base URL — only consulted when NEXT_PUBLIC_API_MOCK is not "true".
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# NOTE: Customer portal currently uses a different flag name
# (NEXT_PUBLIC_USE_MOCK in lib/api/{bookings,extras,routes}.ts). Track this in
# Plan B kickoff: either rename customer flag to NEXT_PUBLIC_API_MOCK for
# consistency, or set both. Setting only one will cause admin/customer to
# silently disagree on mock mode.
