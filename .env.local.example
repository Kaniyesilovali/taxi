# =============================================================================
# Taxsi frontend environment variables
# =============================================================================
# Copy this file to `.env.local` and adjust per environment. All NEXT_PUBLIC_*
# values are baked into the client bundle at build time.
# -----------------------------------------------------------------------------

# Mock mode — customer portal & admin panel
# -----------------------------------------------------------------------------
# When set to "true", lib/api/{routes,extras,bookings}.ts (customer) and
# lib/api/auth.ts (admin) skip network calls and serve fixtures from lib/mock/*.
# Useful for local development without a running backend.
#
# Two flag names exist for historical reasons; set both to keep customer and
# admin in agreement until they're consolidated:
NEXT_PUBLIC_USE_MOCK=true       # consumed by customer portal
NEXT_PUBLIC_API_MOCK=true       # consumed by admin panel

# Backend base URLs
# -----------------------------------------------------------------------------
# Only consulted when the matching mock flag above is NOT "true".
# Customer portal uses NEXT_PUBLIC_API_URL; admin panel uses
# NEXT_PUBLIC_API_BASE_URL. Same backend in practice — different env names will
# be reconciled in a follow-up.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Trustpilot (optional)
# -----------------------------------------------------------------------------
# 24-character business unit ID from business.trustpilot.com. When set, the
# Trustpilot widget on the home page swaps from its hairline placeholder to a
# live TrustBox; when unset, the placeholder is rendered. Locale is
# auto-mapped (EN→en-GB, TR→tr-TR, RU→ru-RU).
# NEXT_PUBLIC_TRUSTPILOT_BUSINESS_ID=

# -----------------------------------------------------------------------------
# Server-only variables (never use NEXT_PUBLIC_ prefix here):
#   STRIPE_SECRET_KEY, SENDGRID_API_KEY, TWILIO_*, etc. — managed by the
#   backend service, not this Next.js app.
# -----------------------------------------------------------------------------
